{
  "author": "Drake Bott",
  "license": "MIT",
  "homepage": "https://github.com/bottd/vite-plugin-norg#README",
  "name": "vite-plugin-norg",
  "version": "4.0.11",
  "type": "module",
  "description": "A Vite plugin for rendering Norg files",
  "main": "dist/plugin/index.js",
  "types": "dist/plugin/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./svelte": {
      "types": "./dist/plugin/types/svelte.d.ts"
    },
    "./react": {
      "types": "./dist/plugin/types/react.d.ts"
    },
    "./vue": {
      "types": "./dist/plugin/types/vue.d.ts"
    },
    "./html": {
      "types": "./dist/plugin/types/html.d.ts"
    },
    "./metadata": {
      "types": "./dist/plugin/types/metadata.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:napi && npm run build:js",
    "build:napi": "napi build --release --platform --esm --output-dir dist/napi/",
    "build:js": "vite build",
    "clean": "rimraf dist target",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "vite",
    "plugin",
    "norg",
    "neorg",
    "wasm",
    "napi",
    "rust",
    "svelte",
    "react",
    "vue"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "svelte": "^5.0.0",
    "vite": "^8.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "dedent": "1.7.2",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@napi-rs/cli": "3.6.2",
    "@rollup/plugin-typescript": "12.3.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "prettier": "3.8.3",
    "react": "19.2.5",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "svelte": "5.55.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bottd/vite-plugin-norg.git"
  }
}
